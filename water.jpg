<script>
(function () {

  /* ── Har 24 ghante baad dikhao ── */
  var STORAGE_KEY = 'appPopupLastShown';
  var ONE_DAY_MS  = 24 * 60 * 60 * 1000;
  var lastShown   = localStorage.getItem(STORAGE_KEY);
  var shouldShow  = !lastShown || (Date.now() - parseInt(lastShown)) >= ONE_DAY_MS;

  /* ── Countdown Timer (10 min) ── */
  var timeLeft = 600;
  function startCountdown() {
    var timer = setInterval(function () {
      timeLeft--;
      var m  = Math.floor(timeLeft / 60);
      var s  = timeLeft % 60;
      var t  = m + ':' + (s < 10 ? '0' : '') + s;
      var e1 = document.getElementById('popupCountdown');
      var e2 = document.getElementById('popupCountdown2');
      if (e1) e1.textContent = t;
      if (e2) e2.textContent = t;
      if (timeLeft <= 0) clearInterval(timer);
    }, 1000);
  }

  /* ── Animated download count ── */
  function animateCount() {
    var current = 1247;
    var el = document.getElementById('downloadCount');
    setInterval(function () {
      current += Math.floor(Math.random() * 3) + 1;
      if (el) el.textContent = current.toLocaleString('en-IN');
    }, Math.floor(Math.random() * 7000) + 8000);
  }

  /* ── Show after 3 seconds ── */
  setTimeout(function () {
    if (!shouldShow) return;

    var overlay = document.getElementById('appPopupOverlay');
    var box     = document.getElementById('appPopupBox');
    overlay.style.display = 'flex';

    setTimeout(function () {
      box.style.transform = 'scale(1)';
      box.style.opacity   = '1';
    }, 30);

    localStorage.setItem(STORAGE_KEY, Date.now().toString());

    startCountdown();
    animateCount();

  }, 3000);

  /* ── Close Function ── */
  window.closeAppPopup = function () {
    var overlay = document.getElementById('appPopupOverlay');
    var box     = document.getElementById('appPopupBox');
    box.style.transform = 'scale(0.8)';
    box.style.opacity   = '0';
    setTimeout(function () { overlay.style.display = 'none'; }, 350);
  };

  /* ── Background click se band ── */
  var el = document.getElementById('appPopupOverlay');
  if (el) {
    el.addEventListener('click', function (e) {
      if (e.target === this) window.closeAppPopup();
    });
  }

})();
</script>
